      "body": { "mimeType": "application/json", "text": "{\n  \"salaId\": 1,\n  \"dataHoraInicio\": \"2026-05-10T09:00:00\",\n  \"dataHoraFim\": \"2026-05-10T10:00:00\",\n  \"responsavel\": \"Matheus Ramos\"\n}" }
    },
